ASPNETCORE_ENVIRONMENT=Development
PORT=8080

# Database Connection (Replace with your actual Railway or Local PostgreSQL URL)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=speedalert;Username=postgres;Password=password

# JWT Authentication Config
Jwt__Issuer=speedalert-api
Jwt__Audience=speedalert-mobile
Jwt__Key=ChangeThisToA32CharacterMinimumSecretKey!

# Speed Limit Provider Config (Google Roads API)
SpeedProvider__ApiKey=YOUR_GOOGLE_API_KEY
SpeedProvider__BaseUrl=https://roads.googleapis.com/v1/

# Logging
Serilog__MinimumLevel__Default=Information
